{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalPassThroughEnv": [
    "NEXT_PUBLIC_SERVER_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "deploy": {
      "cache": false,
      "passThroughEnv": [
        "ALCHEMY_DEPLOY",
        "ALCHEMY_STAGE",
        "ALCHEMY_PASSWORD",
        "ALCHEMY_STATE_TOKEN",
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "CORS_ORIGIN",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_SECRET",
        "NEXT_PUBLIC_SERVER_URL",
        "NEXT_PUBLIC_APP_URL",
        "FROM_EMAIL",
        "RESEND_API_KEY",
        "COOKIE_DOMAIN",
        "LAMBDA_FUNCTION_URL",
        "LAMBDA_REGION",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "SKIP_VIDEO_PROCESSING",
        "SKIP_TRANSCRIPTION",
        "GOOGLE_OAUTH_CLIENT_ID",
        "GOOGLE_OAUTH_CLIENT_SECRET",
        "GOOGLE_OAUTH_REDIRECT_URI",
        "INTEGRATION_ENCRYPTION_KEY",
        "SKIP_DRIVE_EXPORT",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_PRICE_ID_PRO_MONTH",
        "STRIPE_PRICE_ID_PRO_YEAR",
        "STRIPE_PORTAL_RETURN_URL",
        "STRIPE_CHECKOUT_SUCCESS_URL",
        "STRIPE_CHECKOUT_CANCEL_URL"
      ]
    },
    "destroy": {
      "cache": false,
      "passThroughEnv": [
        "ALCHEMY_DEPLOY",
        "ALCHEMY_STAGE",
        "ALCHEMY_PASSWORD",
        "ALCHEMY_STATE_TOKEN",
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID"
      ]
    }
  }
}
