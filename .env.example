# ============================================================
# torea 環境変数
# ============================================================
# このファイルは .env.local のテンプレートです。
# コピーして .env.local を作成し、値を設定してください:
#   cp .env.example .env.local
#
# .env.local はローカル開発専用です（.gitignore 済み）。
# 本番環境の値は GitHub Actions の Secrets / Variables で管理します。
# ============================================================

# --- App Config ---
# Chrome 拡張機能のオリジンも追加する（chrome://extensions で確認）
CORS_ORIGIN=http://localhost:3001
# Better Auth ハンドラ (/api/auth/*) がマウントされている API 側 (Hono Worker)
# の origin。Stripe Checkout の success_url 等のコールバック URL の組み立てに
# 使われるため、必ず Hono server の URL を指定すること。本番では api.torea.app。
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
COOKIE_DOMAIN=localhost
FROM_EMAIL=noreply@example.com

# --- Secrets ---
# 以下は `openssl rand -base64 32` 等で生成してください
BETTER_AUTH_SECRET=
RESEND_API_KEY=

# --- AWS Lambda（動画変換処理）---
# Lambda Function URL（IAM 認証付き）
# ローカルでは未設定で OK（SKIP_VIDEO_PROCESSING がデフォルト true）
LAMBDA_REGION=ap-northeast-1
LAMBDA_FUNCTION_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Video Processing ---
# true にすると fMP4→Progressive MP4 変換をスキップする
# ローカルでは未設定時に自動で true
# 本番では空文字にして Lambda 経由で変換を実行する
# ローカル開発では alchemy.run.ts が自動で true に設定するため、明示指定不要
# SKIP_VIDEO_PROCESSING=

# --- Transcription ---
# true にすると文字起こしをスキップする
# ローカル開発では alchemy.run.ts が自動で true に設定するため、明示指定不要
# SKIP_TRANSCRIPTION=
#
# 注: GROQ_API_KEY は Lambda の環境変数として設定（ローカルでは不要）
# 詳細は docs/lambda-deploy-guide.md を参照

# --- Google Drive 連携 ---
# Google Cloud Console > APIとサービス > 認証情報 で OAuth 2.0 Client ID (ウェブアプリケーション) を作成し、
# 「承認済みリダイレクト URI」に GOOGLE_OAUTH_REDIRECT_URI を登録する。
# scope は drive.file のみ使用（ユーザーの既存 Drive ファイルにはアクセスしない非機密スコープ）。
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google-drive/callback

# 連携アクセストークン / リフレッシュトークンを D1 に保存する際の at-rest 暗号化鍵 (AES-256-GCM)。
# 32 bytes random, base64-encoded:
#   openssl rand -base64 32
# ⚠ 鍵を変更すると既存の暗号化トークンが復号できなくなるため、ローテーション時はトークンの再連携を案内すること
INTEGRATION_ENCRYPTION_KEY=

# true にすると Drive API への送信をスキップする
# ローカル開発では alchemy.run.ts が自動で true に設定するため、明示指定不要
# SKIP_DRIVE_EXPORT=

# --- Stripe (https://dashboard.stripe.com/test/apikeys) ---
# テストモードの key（sk_test_..., pk_test_..., whsec_...）を投入する。
# Phase 1 で Stripe Dashboard 側で Product/Price を作成し、Price ID を反映する。
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_***
# Pro プランの月額 / 年額 Price ID
STRIPE_PRICE_ID_PRO_MONTH=price_***
STRIPE_PRICE_ID_PRO_YEAR=price_***
# Customer Portal / Checkout のリダイレクト先（同一オリジンのみ許可）
# dev では http://localhost:3001/... に書き換える
STRIPE_PORTAL_RETURN_URL=http://localhost:3001/dashboard/settings/billing
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3001/dashboard/settings/billing?status=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3001/pricing?status=canceled

# --- Alchemy (ローカル開発用) ---
# ローカルでは state はファイルシステムに保存されます。
# password はローカル state の暗号化に使用されます（本番と異なる値で OK）。
ALCHEMY_PASSWORD=
