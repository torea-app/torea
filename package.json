{
  "name": "screenbase",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @screenbase/db db:push",
    "db:generate": "turbo -F @screenbase/db db:generate",
    "deploy": "turbo -F @screenbase/infra deploy",
    "destroy": "turbo -F @screenbase/infra destroy",
    "db:seed": "curl -s -X POST http://localhost:3000/api/seed | node -e \"process.stdin.on('data',d=>{const r=JSON.parse(d);console.log(r.success?'✅ Seed complete: '+JSON.stringify(r.summary,null,2)+'\\n\\nLogin: '+r.credentials.email+' / '+r.credentials.password:'❌ '+JSON.stringify(r))})\"",
    "db:reset": "rm -rf .alchemy/miniflare/v3/d1 && rm -f packages/infra/.alchemy/screenbase/dev/database.json",
    "db:auth:generate": "npx auth@latest generate --config packages/auth/src/index.ts --output packages/db/src/schema/auth.ts -y",
    "check": "biome check --write .",
    "knip": "knip",
    "depcruise": "pnpm -F @screenbase/server depcruise"
  },
  "dependencies": {
    "@screenbase/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@cloudflare/workers-types": "catalog:",
    "@screenbase/config": "workspace:*",
    "@types/node": "^22.13.14",
    "dependency-cruiser": "^17.3.10",
    "knip": "^6.0.5",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.23.0"
}
