# ============================================================
# screenbase 環境変数
# ============================================================
# このファイルは .env.local のテンプレートです。
# コピーして .env.local を作成し、値を設定してください:
#   cp .env.example .env.local
#
# .env.local はローカル開発専用です（.gitignore 済み）。
# 本番環境の値は GitHub Actions の Secrets / Variables で管理します。
# ============================================================

# --- App Config ---
# Chrome 拡張機能のオリジンも追加する（chrome://extensions で確認）
CORS_ORIGIN=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
FROM_EMAIL=noreply@example.com

# --- Secrets ---
# 以下は `openssl rand -base64 32` 等で生成してください
BETTER_AUTH_SECRET=
RESEND_API_KEY=

# --- Alchemy (ローカル開発用) ---
# ローカルでは state はファイルシステムに保存されます。
# password はローカル state の暗号化に使用されます（本番と異なる値で OK）。
ALCHEMY_PASSWORD=
