# ============================================================
# screenbase 環境変数
# ============================================================
# このファイルは .env.local のテンプレートです。
# コピーして .env.local を作成し、値を設定してください:
#   cp .env.example .env.local
#
# .env.local はローカル開発専用です（.gitignore 済み）。
# 本番環境の値は GitHub Actions の Secrets / Variables で管理します。
# ============================================================

# --- App Config ---
# Chrome 拡張機能のオリジンも追加する（chrome://extensions で確認）
CORS_ORIGIN=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
COOKIE_DOMAIN=localhost
FROM_EMAIL=noreply@example.com

# --- Secrets ---
# 以下は `openssl rand -base64 32` 等で生成してください
BETTER_AUTH_SECRET=
RESEND_API_KEY=

# --- AWS Lambda（動画変換処理）---
# Lambda Function URL（IAM 認証付き）
# ローカルでは未設定で OK（SKIP_VIDEO_PROCESSING がデフォルト true）
LAMBDA_REGION=ap-northeast-1
LAMBDA_FUNCTION_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Video Processing ---
# true にすると fMP4→Progressive MP4 変換をスキップする
# ローカルでは未設定時に自動で true
# 本番では空文字にして Lambda 経由で変換を実行する
# ローカル開発では alchemy.run.ts が自動で true に設定するため、明示指定不要
# SKIP_VIDEO_PROCESSING=

# --- Alchemy (ローカル開発用) ---
# ローカルでは state はファイルシステムに保存されます。
# password はローカル state の暗号化に使用されます（本番と異なる値で OK）。
ALCHEMY_PASSWORD=

# --- Remote Bindings (ローカル開発用) ---
# true にするとローカル開発でもリモートの D1/R2/KV/Queue を使用する
# Worker コードはローカルで実行し、バインディングだけ本番 Cloudflare に接続
# USE_REMOTE_BINDINGS=true
